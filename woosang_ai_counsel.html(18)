  if (t.includes('개인회생') || t === '1') return '개인회생';
  if (t.includes('개인파산') || t === '2') return '개인파산';
  if (t.includes('민사') || t === '3') return '민사';
  if (t.includes('형사') || t === '4') return '형사';
  if (t.includes('이혼') || t.includes('가사') || t === '5') return '이혼·가사';
  return null;
}

function scrollToBottom() {
  const area = document.getElementById('chatArea');
  const doScroll = () => { area.scrollTop = area.scrollHeight + 5000; };
  doScroll();
  requestAnimationFrame(doScroll);
  setTimeout(doScroll, 50);
  setTimeout(doScroll, 200);
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function escapeHtml(str) {
  if (str === undefined || str === null) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function addMessage(role, text) {
  const area = document.getElementById('chatArea');
  const div = document.createElement('div');
  div.className = `msg ${role === 'user' ? 'user' : 'bot'}`;
  const avatar = role === 'user' ? '👤' : '⚖️';
  div.innerHTML = `
    <div class="msg-avatar">${avatar}</div>
    <div class="msg-bubble">${escapeHtml(text).replace(/\n/g, '<br>')}</div>
  `;
  area.appendChild(div);
  scrollToBottom();
}

function starsHtml(n) {
  n = Math.max(1, Math.min(5, parseInt(n) || 3));
  let html = '<span class="stars">';
  for (let i = 0; i < 5; i++) {
    html += i < n ? '★' : '<span class="dim">★</span>';
  }
  html += '</span>';
  return html;
}

function parseLine(line) {
  let clean = line.trim();
  if (/^\|?[\s\-:|]+\|?$/.test(clean) && clean.includes('-')) return null;
  if (clean.startsWith('|')) {
    const cells = clean.split('|').map(c => c.trim()).filter(c => c.length > 0);
    if (cells.length >= 2) {
      const key = cells[0].replace(/\*/g, '').trim();
      const val = cells[1].replace(/\*/g, '').trim();
      if (key && !/^항목$|^key$/i.test(key)) return { key, val };
      return null;
    }
  }
  clean = clean.replace(/^[\s*\-#>]+/, '').trim();
  let idx = clean.indexOf('|');
  if (idx === -1) idx = clean.indexOf(':');
  if (idx === -1) return null;
  const key = clean.slice(0, idx).replace(/\*/g, '').trim();
  const val = clean.slice(idx + 1).replace(/\*/g, '').trim();
  if (!key) return null;
  return { key, val };
}

function renderSummaryCard(field, labels, values) {
  const area = document.getElementById('chatArea');
  const safeLabels = Array.isArray(labels) ? labels : [];
  const safeValues = Array.isArray(values) ? values : [];
  const rows = safeLabels.map((label, i) => ({ label, value: safeValues[i] || '(답변 없음)' }));
  const card = document.createElement('div');
  card.className = 'result-card';
  if (rows.length === 0) {
    card.innerHTML = `
      <div class="result-title"><span class="badge-icon">📋</span>상담 내용 요약</div>
      <div class="opinion-block">데이터를 불러오는 중 문제가 발생했습니다. (field: ${escapeHtml(field)}, labels: ${safeLabels.length}개, values: ${safeValues.length}개)</div>
    `;
  } else {
    card.innerHTML = `
      <div class="result-title"><span class="badge-icon">📋</span>상담 내용 요약</div>
      <div class="summary-grid">
        ${rows.map(r => `<div class="summary-row"><span class="summary-label">${escapeHtml(r.label)}</span><span class="summary-value">${escapeHtml(r.value)}</span></div>`).join('')}
      </div>
    `;
  }
  area.appendChild(card);
  scrollToBottom();
}

function renderAnalysisCard(rawText) {
  const area = document.getElementById('chatArea');
  const analysisMatch = rawText.match(/\[\[\s*ANALYSIS_START\s*\]\]([\s\S]*?)\[\[\s*ANALYSIS_END\s*\]\]/i);

  let stars = 3, grade = 'B', opinion = '', check = [];
  if (analysisMatch) {
    const parsed = analysisMatch[1].trim().split('\n').map(parseLine).filter(Boolean);
    parsed.forEach(({ key, val }) => {
      const k = key.toUpperCase();
      if (k === 'STARS') stars = val;
      else if (k === 'GRADE') grade = val;
      else if (k === 'OPINION') opinion = val;
      else if (k === 'CHECK') check = val.split(',').map(s => s.trim()).filter(Boolean);
    });
  }
  if (!opinion) {
    opinion = '현재 입력된 내용을 바탕으로 1차 검토가 가능합니다. 정확한 판단을 위해서는 추가 자료 확인과 변호사 상담이 필요합니다.';
  }

  const card = document.createElement('div');
  card.className = 'result-card';
  card.innerHTML = `
    <div class="result-title"><span class="badge-icon">⚖️</span>AI 1차 분석</div>
    <div class="summary-grid">
      <div class="summary-row"><span class="summary-label">검토 가능성</span><span class="summary-value">${starsHtml(stars)}</span></div>
      <div class="summary-row"><span class="summary-label">상담 난이도</span><span class="summary-value"><span class="grade-badge">${escapeHtml(grade)}</span></span></div>
    </div>
    <div style="margin-top:20px;">
      <div class="section-label">검토 의견</div>
      <div class="opinion-block">${escapeHtml(opinion)}</div>
    </div>
    ${check.length ? `
    <div style="margin-top:18px;">
      <div class="section-label">추가 확인 사항</div>
      <div class="check-block"><ul>${check.map(c => `<li><span style="color:var(--gold); font-weight:700;">✓</span>${escapeHtml(c)}</li>`).join('')}</ul></div>
    </div>` : ''}
    <div class="reserve-banner">
      무료 상담 예약을 원하시면 <b>'상담예약'</b>이라고 입력해주세요.<br>
      우상법률사무소 ☎ <a href="tel:02-927-9665">02-927-9665</a>
    </div>
  `;
  area.appendChild(card);
  scrollToBottom();
}

function addChoices(choices) {
  const area = document.getElementById('chatArea');
  const div = document.createElement('div');
  div.className = 'choices';
  div.id = 'choices';
  choices.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.textContent = c;
    btn.onclick = () => {
      document.getElementById('choices')?.remove();
      document.getElementById('userInput').value = c;
      sendMessage();
    };
    div.appendChild(btn);
  });
  area.appendChild(div);
  scrollToBottom();
}

function showTyping() {
  const area = document.getElementById('chatArea');
  const div = document.createElement('div');
  div.className = 'msg bot';
  div.id = 'typing';
  div.innerHTML = `<div class="msg-avatar">⚖️</div><div class="msg-bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
  area.appendChild(div);
  scrollToBottom();
}

function removeTyping() {
  document.getElementById('typing')?.remove();
}

async function callClaude(systemPrompt, userMessage) {
  const response = await fetch('https://woosang-ai-proxy.indy1913.workers.dev', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-6',
      max_tokens: 600,
      system: systemPrompt,
      messages: [{ role: 'user', content: userMessage }]
    })
  });
  const data = await response.json();
  if (!data || !data.content || !data.content[0] || typeof data.content[0].text !== 'string') {
    console.error('[AI 상담원] 예상치 못한 API 응답 구조:', JSON.stringify(data));
    throw new Error('API 응답 형식 오류');
  }
  return data.content[0].text.trim();
}

async function getReaction(userAnswer) {
  try {
    return await callClaude(REACT_SYSTEM_PROMPT, `고객 답변: "${userAnswer}"`);
  } catch (e) {
    return '네, 알겠습니다.';
  }
}

async function getAnalysis(field, labels, values) {
  const summaryText = labels.map((l, i) => `${l}: ${values[i] || '-'}`).join('\n');
  try {
    const result = await callClaude(ANALYSIS_SYSTEM_PROMPT, `상담 분야: ${field}\n\n${summaryText}\n\n위 내용을 바탕으로 분석 결과를 출력해주세요.`);
    console.log('[AI 상담원] 분석 응답:', result);
    return result;
  } catch (e) {
    console.error('[AI 상담원] 분석 요청 실패:', e);
    return '';
  }
}

async function askNextQuestion() {
  const field = FIELDS[currentField];
  currentStep++;
  if (currentStep < field.questions.length) {
    showTyping();
    await new Promise(r => setTimeout(r, 400));
    removeTyping();
    addMessage('bot', field.questions[currentStep]);
  } else {
    // 모든 질문 완료 — 결과 출력
    showTyping();
    renderSummaryCard(currentField, field.labels, answers);
    const analysisReply = await getAnalysis(currentField, field.labels, answers);
    removeTyping();
    renderAnalysisCard(analysisReply);
    currentField = null;
    currentStep = -1;
    answers = [];
  }
}

async function sendMessage() {
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text || isLoading) return;

  document.getElementById('choices')?.remove();
  input.value = '';
  input.style.height = 'auto';
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  addMessage('user', text);

  try {
    if (currentField === null) {
      // 분야 선택 단계
      const field = detectField(text);
      if (field) {
        currentField = field;
        currentStep = -1;
        answers = [];
        showTyping();
        await new Promise(r => setTimeout(r, 400));
        removeTyping();
        addMessage('bot', `${field} 상담을 선택하셨군요. 몇 가지 여쭤보겠습니다.`);
        await askNextQuestion();
      } else {
        showTyping();
        const reply = await getReaction(text) ;
        removeTyping();
        addMessage('bot', '죄송합니다, 상담 분야를 다시 한번 선택해주시겠어요?\n① 개인회생 ② 개인파산 ③ 민사 ④ 형사 ⑤ 이혼·가사');
        addChoices(['① 개인회생', '② 개인파산', '③ 민사', '④ 형사', '⑤ 이혼·가사']);
      }
    } else {
      // 질문 응답 단계
      answers[currentStep] = text;
      showTyping();
      const reaction = await getReaction(text);
      removeTyping();
      addMessage('bot', reaction);
      await askNextQuestion();
    }
  } catch (e) {
    removeTyping();
    addMessage('bot', '일시적인 오류가 발생했습니다. 잠시 후 다시 시도해주세요.\n전화 상담: 02-927-9665');
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  scrollToBottom();
}

function init() {
  addMessage('bot', '안녕하세요.\n우상법률사무소 AI 상담원입니다.\n상담받고 싶은 분야를 선택해주세요.\n① 개인회생 ② 개인파산 ③ 민사 ④ 형사 ⑤ 이혼·가사\n번호 또는 상담 분야를 입력해주세요.');
  addChoices(['① 개인회생', '② 개인파산', '③ 민사', '④ 형사', '⑤ 이혼·가사']);
}

init();

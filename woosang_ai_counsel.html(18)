    area.scrollTop = area.scrollHeight;
  };

  doScroll();
  requestAnimationFrame(doScroll);
  setTimeout(doScroll, 80);
  setTimeout(doScroll, 250);
  setTimeout(doScroll, 600);
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function escapeHtml(str = '') {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function addMessage(role, text) {
  const area = document.getElementById('chatArea');
  const div = document.createElement('div');
  div.className = `msg ${role === 'user' ? 'user' : 'bot'}`;
  const avatar = role === 'user' ? '👤' : '⚖️';
  div.innerHTML = `
    <div class="msg-avatar">${avatar}</div>
    <div class="msg-bubble">${escapeHtml(text).replace(/\n/g, '<br>')}</div>
  `;
  area.appendChild(div);
  scrollToBottom();
}

function starsHtml(n) {
  n = Math.max(1, Math.min(5, parseInt(n) || 3));
  let html = '<span class="stars">';
  for (let i = 0; i < 5; i++) {
    html += i < n ? '★' : '<span class="dim">★</span>';
  }
  html += '</span>';
  return html;
}

function parseLine(line) {
  // "항목|값" 또는 "항목: 값" 형식 모두 지원, 앞에 markdown 기호(*, -, 공백)가 있어도 제거
  let clean = line.replace(/^[\s*\-#>]+/, '').trim();
  let idx = clean.indexOf('|');
  if (idx === -1) idx = clean.indexOf(':');
  if (idx === -1) return null;
  const key = clean.slice(0, idx).replace(/\*/g, '').trim();
  const val = clean.slice(idx + 1).replace(/\*/g, '').trim();
  if (!key) return null;
  return { key, val };
}

function renderResultCards(rawText) {
  const area = document.getElementById('chatArea');
  if (!area || !rawText) return false;

  // 일반 상담 질문 답변에는 결과 마커가 없으므로 카드 렌더링하지 않음
  if (
    !rawText.includes('[[SUMMARY_START]]') &&
    !rawText.includes('[[ANALYSIS_START]]')
  ) {
    return false;
  }

  const summaryMatch = rawText.match(/\[\[\s*SUMMARY_START\s*\]\]([\s\S]*?)\[\[\s*SUMMARY_END\s*\]\]/i);
  const analysisMatch = rawText.match(/\[\[\s*ANALYSIS_START\s*\]\]([\s\S]*?)\[\[\s*ANALYSIS_END\s*\]\]/i);

  let rendered = false;

  if (summaryMatch) {
    const rows = summaryMatch[1]
      .trim()
      .split(/\r?\n+/)
      .map(parseLine)
      .filter(Boolean)
      .map(r => ({ label: r.key, value: r.val }));

    if (rows.length > 0) {
      rendered = true;

      const card = document.createElement('div');
      card.className = 'result-card';

      card.innerHTML = `
        <div class="result-title"><span class="badge-icon">📋</span>상담 내용 요약</div>
        <div class="summary-grid">
          ${rows.map(r => `
            <div class="summary-row">
              <span class="summary-label">${escapeHtml(r.label)}</span>
              <span class="summary-value">${escapeHtml(r.value)}</span>
            </div>
          `).join('')}
        </div>
      `;

      area.appendChild(card);
    }
  }

  if (analysisMatch) {
    const parsed = analysisMatch[1]
      .trim()
      .split(/\r?\n+/)
      .map(parseLine)
      .filter(Boolean);

    let stars = 3;
    let grade = 'B';
    let opinion = '';
    let check = [];

    parsed.forEach(({ key, val }) => {
      const k = key.toUpperCase().trim();

      if (k === 'STARS') stars = val;
      else if (k === 'GRADE') grade = val;
      else if (k === 'OPINION') opinion = val;
      else if (k === 'CHECK') check = val.split(',').map(s => s.trim()).filter(Boolean);
    });

    rendered = true;

    const card = document.createElement('div');
    card.className = 'result-card';

    card.innerHTML = `
      <div class="result-title"><span class="badge-icon">⚖️</span>AI 1차 분석</div>

      <div class="summary-grid">
        <div class="summary-row">
          <span class="summary-label">검토 가능성</span>
          <span class="summary-value">${starsHtml(stars)}</span>
        </div>
        <div class="summary-row">
          <span class="summary-label">상담 난이도</span>
          <span class="summary-value"><span class="grade-badge">${escapeHtml(grade)}</span></span>
        </div>
      </div>

      <div style="margin-top:20px;">
        <div class="section-label">검토 의견</div>
        <div class="opinion-block">${escapeHtml(opinion || '입력된 내용을 기준으로 변호사 상담을 통해 구체적인 검토가 필요합니다.')}</div>
      </div>

      ${check.length ? `
      <div style="margin-top:18px;">
        <div class="section-label">추가 확인 사항</div>
        <div class="check-block">
          <ul>
            ${check.map(c => `
              <li><span style="color:var(--gold); font-weight:700;">✓</span>${escapeHtml(c)}</li>
            `).join('')}
          </ul>
        </div>
      </div>` : ''}

      <div class="reserve-banner">
        무료 상담 예약을 원하시면 <b>'상담예약'</b>이라고 입력해주세요.<br>
        우상법률사무소 ☎ <a href="tel:02-927-9665">02-927-9665</a>
      </div>
    `;

    area.appendChild(card);
  }

  if (rendered) {
    document.querySelectorAll('.result-spacer').forEach(el => el.remove());
    const spacer = document.createElement('div');
    spacer.style.height = '170px';
    spacer.className = 'result-spacer';
    area.appendChild(spacer);
  }

  scrollToBottom();
  return rendered;
}

function addChoices(choices) {
  const area = document.getElementById('chatArea');
  const div = document.createElement('div');
  div.className = 'choices';
  div.id = 'choices';
  choices.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.textContent = c;
    btn.onclick = () => {
      document.getElementById('choices')?.remove();
      document.getElementById('userInput').value = c;
      sendMessage();
    };
    div.appendChild(btn);
  });
  area.appendChild(div);
  scrollToBottom();
}

function showTyping() {
  const area = document.getElementById('chatArea');
  const div = document.createElement('div');
  div.className = 'msg bot';
  div.id = 'typing';
  div.innerHTML = `<div class="msg-avatar">⚖️</div><div class="msg-bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
  area.appendChild(div);
  scrollToBottom();
}

function removeTyping() {
  document.getElementById('typing')?.remove();
}

async function callClaude(userMessage) {
  messages.push({ role: 'user', content: userMessage });

  const response = await fetch('https://woosang-ai-proxy.indy1913.workers.dev', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-6',
      max_tokens: 1200,
      system: SYSTEM_PROMPT,
      messages: messages
    })
  });

  if (!response.ok) {
    const errText = await response.text().catch(() => '');
    console.error('[AI 상담원] API 오류:', response.status, errText);
    throw new Error('API 응답 오류: ' + response.status);
  }

  const data = await response.json();
  console.log('[AI 상담원] API 원본 응답:', data);

  let reply = '';

  if (data?.content?.[0]?.text) {
    reply = data.content[0].text;
  } else if (typeof data?.content === 'string') {
    reply = data.content;
  } else if (typeof data?.reply === 'string') {
    reply = data.reply;
  } else if (typeof data?.text === 'string') {
    reply = data.text;
  } else if (typeof data?.message === 'string') {
    reply = data.message;
  } else if (data?.error) {
    console.error('[AI 상담원] API error:', data.error);
    throw new Error('AI 오류: ' + JSON.stringify(data.error));
  } else {
    throw new Error('AI 응답 형식을 읽지 못했습니다.');
  }

  messages.push({ role: 'assistant', content: reply });
  return reply;
}

async function sendMessage() {
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text || isLoading) return;

  document.getElementById('choices')?.remove();
  input.value = '';
  input.style.height = 'auto';
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  addMessage('user', text);
  showTyping();

  try {
    const reply = await callClaude(text);
    removeTyping();

    const rendered = renderResultCards(reply);
    if (!rendered) {
      addMessage('bot', reply);
    }

    if (messages.length === 2) {
      addChoices(['① 개인회생', '② 개인파산', '③ 민사', '④ 형사', '⑤ 이혼·가사']);
    }
  } catch (e) {
    removeTyping();
    addMessage('bot', '일시적인 오류가 발생했습니다. 잠시 후 다시 시도해주세요.\n전화 상담: 02-927-9665');
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  scrollToBottom();
}

async function init() {
  showTyping();
  try {
    const reply = await callClaude('시작');
    removeTyping();
    addMessage('bot', reply);
    addChoices(['① 개인회생', '② 개인파산', '③ 민사', '④ 형사', '⑤ 이혼·가사']);
  } catch(e) {
    removeTyping();
    addMessage('bot', '안녕하세요.\n우상법률사무소 AI 상담원입니다.\n상담받고 싶은 분야를 선택해주세요.\n① 개인회생 ② 개인파산 ③ 민사 ④ 형사 ⑤ 이혼·가사');
    addChoices(['① 개인회생', '② 개인파산', '③ 민사', '④ 형사', '⑤ 이혼·가사']);
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}
</script>
